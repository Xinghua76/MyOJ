# DeepSeek AI 配置
# 从 https://platform.deepseek.com 获取 API Key
AI_DEEPSEEK_API_KEY=your-deepseek-api-key-here
AI_DEEPSEEK_MODEL=deepseek-chat
AI_DEEPSEEK_URL=https://api.deepseek.com/v1/chat/completions

# 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/code_arena?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf8
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=123456

# Redis 配置
SPRING_REDIS_PASSWORD=123456

# 邮件账户配置
SPRING_MAIL_USERNAME=your-email@qq.com
SPRING_MAIL_PASSWORD=your-app-password

# 阿里云短信配置
ALIYUN_SMS_APPCODE=your-appcode
